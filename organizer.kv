#:import CategoryCard ui.dashboard.CategoryCard
#:import FilePreviewItem ui.dashboard.FilePreviewItem

<CategoryCard>:
    orientation: "vertical"
    padding: "12dp"
    spacing: "8dp"
    size_hint_y: None
    height: "110dp"
    md_bg_color: self.bg_color
    radius: [12, 12, 12, 12]
    elevation: 1.5

    BoxLayout:
        orientation: "horizontal"
        size_hint_y: None
        height: "36dp"
        
        MDIcon:
            icon: root.icon_name
            font_size: "32sp"
            theme_text_color: "Custom"
            text_color: [1, 1, 1, 0.9]
            size_hint_x: None
            width: "36dp"
            halign: "left"
            
        Widget: # spacer

    MDLabel:
        text: root.category_name
        font_style: "Subtitle1"
        theme_text_color: "Custom"
        text_color: [1, 1, 1, 0.9]
        bold: True
        size_hint_y: None
        height: "20dp"

    MDLabel:
        text: str(root.file_count) + " files"
        font_style: "Caption"
        theme_text_color: "Custom"
        text_color: [1, 1, 1, 0.75]
        size_hint_y: None
        height: "16dp"

<FilePreviewItem>:
    orientation: "horizontal"
    padding: ["12dp", "8dp", "12dp", "8dp"]
    size_hint_y: None
    height: "64dp"
    spacing: "12dp"
    canvas.before:
        Color:
            rgba: [0.95, 0.95, 0.95, 1] if self.index % 2 == 0 else [1, 1, 1, 1]
        Rectangle:
            pos: self.pos
            size: self.size

    MDIcon:
        icon: "file-swap-outline"
        font_size: "24sp"
        theme_text_color: "Secondary"
        size_hint_x: None
        width: "24dp"
        pos_hint: {"center_y": 0.5}

    BoxLayout:
        orientation: "vertical"
        pos_hint: {"center_y": 0.5}
        
        MDLabel:
            text: root.filename
            font_style: "Body1"
            bold: True
            theme_text_color: "Primary"
            shorten: True
            shorten_from: "right"
            
        MDLabel:
            text: "→ " + root.target_path
            font_style: "Caption"
            theme_text_color: "Secondary"
            shorten: True
            shorten_from: "center"

# Main Screen Layout
MDScreen:
    BoxLayout:
        orientation: "vertical"
        
        MDTopAppBar:
            title: "Smart File Organizer"
            anchor_title: "left"
            elevation: 2
            right_action_items: [["help-circle-outline", lambda x: app.show_help()]]
            
        BoxLayout:
            orientation: "vertical"
            padding: "16dp"
            spacing: "16dp"
            
            # Directory Picker Row
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: "64dp"
                spacing: "8dp"
                
                MDTextField:
                    id: dir_input
                    hint_text: "Select folder to organize"
                    text: app.target_dir
                    on_text: app.on_dir_text_change(self.text)
                    helper_text_mode: "on_error"
                    pos_hint: {"center_y": 0.5}
                    
                MDIconButton:
                    icon: "folder-open"
                    theme_icon_color: "Custom"
                    icon_color: app.theme_cls.primary_color
                    pos_hint: {"center_y": 0.5}
                    on_release: app.open_folder_picker()
                    
            # Scrollable main container
            ScrollView:
                do_scroll_x: False
                
                BoxLayout:
                    orientation: "vertical"
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: "20dp"
                    padding: ["0dp", "4dp", "0dp", "16dp"]
                    
                    # Category Statistics Section
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: "8dp"
                        
                        MDLabel:
                            text: "Files in Directory"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Primary"
                            size_hint_y: None
                            height: "36dp"
                            
                        MDGridLayout:
                            id: stats_grid
                            cols: 2
                            adaptive_height: True
                            spacing: "12dp"
                            # Cards will be dynamically updated in python code
                            
                    # Preview Changes Section
                    BoxLayout:
                        orientation: "vertical"
                        size_hint_y: None
                        height: self.minimum_height
                        spacing: "8dp"
                        
                        MDLabel:
                            text: "Proposed Changes (Dry Run)"
                            font_style: "H6"
                            bold: True
                            theme_text_color: "Primary"
                            size_hint_y: None
                            height: "36dp"
                            
                        MDCard:
                            orientation: "vertical"
                            radius: [12, 12, 12, 12]
                            padding: "4dp"
                            size_hint_y: None
                            height: "220dp"
                            elevation: 1
                            
                            ScrollView:
                                do_scroll_x: False
                                
                                BoxLayout:
                                    id: preview_list
                                    orientation: "vertical"
                                    size_hint_y: None
                                    height: self.minimum_height
                                    
                                    # If empty, this label will be visible
                                    MDLabel:
                                        id: empty_preview_label
                                        text: "No changes proposed. Select a folder and click SCAN."
                                        halign: "center"
                                        valign: "center"
                                        theme_text_color: "Secondary"
                                        font_style: "Body2"
                                        size_hint_y: None
                                        height: "120dp"


            # Bottom Button Control Bar
            BoxLayout:
                orientation: "horizontal"
                size_hint_y: None
                height: "56dp"
                spacing: "12dp"
                
                MDRectangleFlatButton:
                    id: btn_undo
                    text: "UNDO LAST"
                    icon: "undo"
                    size_hint_x: 0.3
                    disabled: True
                    on_release: app.trigger_undo()
                    
                MDRectangleFlatButton:
                    id: btn_scan
                    text: "SCAN"
                    icon: "magnify"
                    size_hint_x: 0.3
                    disabled: True
                    on_release: app.trigger_scan()
                    
                MDRaisedButton:
                    id: btn_organize
                    text: "ORGANIZE"
                    icon: "folder-sync"
                    size_hint_x: 0.4
                    disabled: True
                    on_release: app.trigger_organize()
